# -------------------------
# Runtime data
# -------------------------

# Ignore all datasets by default
data/datasets/**

# But allow demo dataset folder
!data/datasets/demo/
!data/datasets/demo/**

# Inside demo, only allow small parquet files
!data/datasets/demo/*.parquet

# Session files, references, snapshots, workspace state, saved queries
data/sessions/
data/references/
data/snapshots/
data/workspace.json
data/queries.json

# Environmental Variables

.env